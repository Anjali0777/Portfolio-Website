<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Portfolio with Animated Projects</title>
    <style>
        /* Global styles */
        body {
            font-family: Arial, sans-serif;
            background-color: #f0f0f0;
            margin: 0;
            padding: 0;
        }
        .container {
            max-width: 1200px;
            margin: 20px auto;
            text-align: center;
            display: flex;
            flex-direction: column; /* Ensure container is column layout */
            align-items: center; /* Center items horizontally */
        }
        .laptop {
            position: relative;
            width: 800px;
            height: 500px;
            margin: 0 auto;
            background-color: #333;
            border-radius: 10px;
            overflow: hidden;
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.3);
        }
        .screen {
            position: absolute;
            top: 20px;
            left: 20px;
            right: 20px;
            bottom: 20px;
            background-color: #fff;
            border-radius: 5px;
            overflow: hidden;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 24px;
            color: #333;
            transition: transform 0.3s ease, opacity 0.3s ease, visibility 0s linear 0.3s; /* Added visibility transition */
            transform-style: preserve-3d; /* Enable 3D transformations */
            backface-visibility: hidden; /* Hide backface during animation */
        }
        .screen > div {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            backface-visibility: hidden; /* Hide backface during animation */
        }
        .screen.front {
            transform: rotateY(0deg);
            z-index: 2;
        }
        .screen.back {
            transform: rotateY(-180deg); /* Initially flip to hide */
            z-index: 1;
        }
        .nav-link {
            position: absolute;
            display: block;
            width: 80px;
            height: 20px;
            background-color: rgba(255, 255, 255, 0.8);
            border-radius: 5px;
            text-align: center;
            font-size: 14px;
            line-height: 20px;
            color: #333;
            cursor: pointer;
            transition: background-color 0.3s ease, transform 0.2s ease; /* Added transitions */
        }
        .nav-link:hover {
            background-color: #ffc107;
            transform: scale(1.1); /* Example of scale animation on hover */
        }
        .nav-link:nth-child(1) {
            top: 20px;
            left: 20px;
        }
        .nav-link:nth-child(2) {
            top: 20px;
            right: 20px;
        }
        .nav-link:nth-child(3) {
            bottom: 20px;
            left: 20px;
        }
        .nav-link:nth-child(4) {
            bottom: 20px;
            right: 20px;
        }

        /* Example of @keyframes animation */
        @keyframes fadeInOut {
            0% { opacity: 0; transform: scale(0.9); }
            50% { opacity: 1; transform: scale(1.05); }
            100% { opacity: 0; transform: scale(0.9); }
        }

        /* Apply @keyframes animation to .screen */
        .screen.animate {
            animation: fadeInOut 2s ease-in-out;
        }

        /* Project section styles */
        .projects {
            width: 100%; /* Full width */
            max-width: 800px; /* Limit max width to laptop size */
            margin-top: 20px; /* Space between laptop and projects */
            opacity: 0;
            transform: translateY(50px);
            transition: opacity 0.5s ease, transform 0.5s ease;
            display: flex;
            justify-content: center;
            align-items: center;
            flex-wrap: wrap;
        }
        .project {
            width: 300px;
            margin: 20px;
            padding: 20px;
            background-color: #fff;
            border-radius: 10px;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            text-align: left;
            cursor: pointer; /* Added cursor pointer for better UX */
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        .project:hover {
            transform: translateY(-10px);
            box-shadow: 0 8px 16px rgba(0, 0, 0, 0.2);
        }
        .project h3 {
            font-size: 20px;
            margin-bottom: 10px;
        }
        .project p {
            font-size: 16px;
            margin-bottom: 20px;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="laptop">
            <div class="screen front">
                <div>
                    <p>Welcome to My Portfolio</p>
                </div>
            </div>
            <div class="screen back">
                <div>
                    <p>Project Details</p>
                </div>
            </div>
            <a href="#" class="nav-link" onclick="showSection('home')">Home</a>
            <a href="#" class="nav-link" onclick="showSection('projects')">Projects</a>
            
            <a href="#" class="nav-link" onclick="showSection('projects')">Projects</a>
	
        </div>

        <!-- Projects Section -->
        <div class="projects">
            <div class="project" onclick="showProjectDetails('Minesweeper Game', 'A classic game built with JavaScript.')">
                <h3>Minesweeper Game</h3>
                <p>A classic game built with JavaScript.</p>
            </div>
            <div class="project" onclick="showProjectDetails('Image Editor', 'An online tool for editing images.')">
                <h3>Image Editor</h3>
                <p>An online tool for editing images.</p>
            </div>
            <div class="project" onclick="showProjectDetails('Portfolio Website', 'My personal portfolio website built with HTML, CSS, and JavaScript.')">
                <h3>Portfolio Website</h3>
                <p>My personal portfolio website built with HTML, CSS, and JavaScript.</p>
            </div>
        </div>
    </div>

    <script>
        function showSection(section) {
            const frontScreen = document.querySelector('.screen.front');
            const backScreen = document.querySelector('.screen.back');
            frontScreen.classList.remove('animate');
            backScreen.classList.remove('animate');

            switch (section) {
                case 'home':
                    frontScreen.innerHTML = '<div><p>Welcome to My Portfolio</p></div>';
                    break;
                case 'projects':
                    frontScreen.innerHTML = '<div><p>My Projects</p></div>';
                    backScreen.innerHTML = '<div><p>Select a project to view details.</p></div>';
                    showProjectsSection();
                    break;
                case 'about':
                    frontScreen.innerHTML = '<div><p>About Me</p></div>';
                    break;
                case 'contact':
                    frontScreen.innerHTML = '<div><p>Contact Me</p></div>';
                    break;
                default:
                    frontScreen.innerHTML = '<div><p>Welcome to My Portfolio</p></div>';
                    break;
            }

            void frontScreen.offsetWidth;
            void backScreen.offsetWidth;

            frontScreen.classList.add('animate');
            backScreen.classList.add('animate');
        }

        function showProjectsSection() {
            const projects = document.querySelector('.projects');
            projects.style.opacity = '1';
            projects.style.transform = 'translateY(0)';
        }

        function showProjectDetails(title, description) {
            const frontScreen = document.querySelector('.screen.front');
            const backScreen = document.querySelector('.screen.back');

            // Update back screen with project details
            backScreen.innerHTML = `
                <div>
                    <h3>${title}</h3>
                    <p>${description}</p>
                </div>
            `;

            // Flip screens
            frontScreen.classList.remove('animate');
            backScreen.classList.remove('animate');

            void frontScreen.offsetWidth;
            void backScreen.offsetWidth;

            frontScreen.style.transform = 'rotateY(180deg)';
            backScreen.style.transform = 'rotateY(0deg)';

            frontScreen.classList.add('animate');
            backScreen.classList.add('animate');
        }
    </script>
</body>
</html>
